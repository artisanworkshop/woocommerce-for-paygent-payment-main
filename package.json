{
	"name": "paygent-for-woocommerce",
	"title": "Paygent for WooCommerce",
	"version": "1.4.0",
	"license": "GPL-3.0",
	"homepage": "https://wordpress.org/plugins/woocommerce-for-paygent-payment-main/",
	"repository": {
		"type": "github",
		"url": "https://github.com/artisanworkshop/woocommerce-for-paygent-payment-main.git"
	},
	"devDependencies": {
		"@woocommerce/dependency-extraction-webpack-plugin": "2.2.0",
		"@wordpress/scripts": "^30.0.2",
		"cross-env": "7.0.3",
		"webpack-cli": "^6.0.1"
	},
	"scripts": {
		"start": "wp-scripts start && wp-env logs",
		"build": "wp-scripts build && npm run i18n:build",
		"i18n": "npm run i18n:build",
		"packages-update": "wp-scripts packages-update",
		"check-engines": "wp-scripts check-engines",
		"make-pot": "wp-env run cli --env-cwd=wp-content/plugins/woocommerce-for-paygent-payment-main/ wp i18n make-pot ./ i18n/woocommerce-for-paygent-payment-main.pot --ignore-domain",
		"make-json": "wp-env run cli --env-cwd=wp-content/plugins/woocommerce-for-paygent-payment-main/ wp i18n make-json i18n --no-purge"
	}
}
