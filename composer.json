{
	"name": "artisanworkshop/paygent-for-woocommerce",
	"description": "Paygent for WooCommerce",
	"license": "GPL-3.0-or-later",
	"version": "2.4.0",
	"type": "wordpress-plugin",
	"authors": [
		{
			"name": "Shohei Tanaka",
			"homepage": "https://wc.artws.info/"
		}
	],
	"require": {
		"php": ">=7.4",
		"symfony/yaml": "^2.8 || ^3.0 || ^4.0 || ^5.0 || ^6.4 || ^7.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5",
		"brain/monkey": "^2.6",
		"mockery/mockery": "^1.6",
		"yoast/phpunit-polyfills": "^2.0",
		"wp-phpunit/wp-phpunit": "^6.9"
	},
	"autoload": {
		"psr-4": {
			"PaygentModule\\": "src/paygent_module"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Paygent\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"test": "phpunit",
		"test:unit": "phpunit --testsuite unit",
		"test:integration": "phpunit --configuration phpunit-integration.xml.dist",
		"test:integration:wp-env": "bin/run-integration-tests.sh",
		"phpcs": "phpcs --standard=WordPress includes/ class-wc-gateway-paygent.php woocommerce-for-paygent-payment-main.php",
		"phpcbf": "phpcbf --standard=WordPress includes/ class-wc-gateway-paygent.php woocommerce-for-paygent-payment-main.php",
		"phpstan": "phpstan analyse"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
